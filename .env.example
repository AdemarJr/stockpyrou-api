# Variáveis do Railway (Variables do serviço) — não commitar .env com senha

# Supabase Postgres (Connect → Transaction pooler, porta 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# CORS do frontend
FRONTEND_URL=https://stockpyrou.com.br

# PORT e HOST: Railway injeta PORT; HOST padrão 0.0.0.0
# PORT=3001
# HOST=0.0.0.0
