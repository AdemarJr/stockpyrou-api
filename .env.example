# Variáveis do Railway (Variables do serviço) — não commitar .env com senha
#
# Serviço: https://stockpyrou-api-production.up.railway.app
# Banco: EasyPanel Postgres → database stock-pyrou

# Postgres EasyPanel (senha com ! @ * precisa URL-encode: %21 %40 %2A)
DATABASE_URL=postgresql://pyrouwebdb:SENHA_ENCODED@easypanel.pyrou.com.br:5432/stock-pyrou?sslmode=disable

# CORS do frontend
FRONTEND_URL=https://stockpyrou.com.br

# PORT e HOST: Railway injeta PORT; HOST padrão 0.0.0.0
# PORT=3001
# HOST=0.0.0.0
